{
  "name": "Onjoomilkyway-superRoulette",
  "version": "1.0.0",
  "description": "Professional Onjoomilkyway superRoulette Automation Desktop Application",
  "main": "src/main.js",
  "homepage": "./",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev --inspect=5858",
    "build": "electron-builder --win",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "dist": "npm run build",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/ components/ database/ --ext .js",
    "lint:fix": "eslint src/ components/ database/ --ext .js --fix",
    "packager": "electron-packager . Onjoomilkyway-superRoulette --out=dist/ --overwrite --platform=win32 --arch=x64 --asar",
    "clean": "rimraf dist build",
    "prebuild": "npm run clean",
    "serve": "webpack serve --mode development",
    "build:webpack": "webpack --mode production"
  },
  "keywords": [
    "Onjoomilkyway",
    "superRoulette",
    "automation",
    "electron",
    "desktop-app",
    "gaming",
    "bot"
  ],
  "author": {
    "name": "Your Name",
    "email": "your.email@domain.com"
  },
  "license": "MIT",
  "build": {
    "appId": "com.Onjoomilkyway.superRoulette",
    "productName": "Onjoomilkyway superRoulette",
    "copyright": "Copyright © 2024",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "components/**/*",
      "database/**/*",
      "data/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "data/",
        "to": "data/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.jpg",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Onjoomilkyway superRoulette"
    }
  },
  "dependencies": {
    "axios": "^1.13.2",
    "chalk": "^5.6.2",
    "config": "^4.1.1",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.6.2",
    "firebase": "^12.6.0",
    "fs-extra": "^11.3.2",
    "hpagent": "^1.2.0",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "path": "^0.12.7",
    "sqlite3": "^5.1.7",
    "uuid": "^13.0.0",
    "winston": "^3.18.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "babel-jest": "^30.2.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.2",
    "electron": "^39.2.2",
    "electron-builder": "^26.0.12",
    "electron-devtools-installer": "^4.0.0",
    "electron-packager": "^17.1.2",
    "electron-reload": "^2.0.0-alpha.1",
    "eslint": "^8.57.1",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-html": "^8.1.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.6.0",
    "html-webpack-plugin": "^5.6.5",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.2.6",
    "mini-css-extract-plugin": "^2.9.4",
    "nodemon": "^3.1.11",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.0",
    "style-loader": "^4.0.0",
    "webpack": "^5.103.0",
    "webpack-cli": "^6.0.1"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/Onjoomilkyway-superRoulette.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/Onjoomilkyway-superRoulette/issues"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npx lint-staged"
    }
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "git add"
    ],
    "*.{json,md}": [
      "prettier --write",
      "git add"
    ]
  }
}
